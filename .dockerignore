# Reinstalled / rebuilt inside the image
node_modules
**/node_modules
dist
**/dist
**/.tsbuildinfo

# VCS & local agent state
.git
.gitignore
.local
.agents

# Local env / secrets — never bake into the image
.env
.env.*
!.env.example

# Replit-specific dev metadata (production is Replit-free)
.replit
.config
.cache
.upm
replit.nix

# Editor / OS noise
.vscode
.idea
*.log
.DS_Store

# Large local-only assets not imported by the build
attached_assets
