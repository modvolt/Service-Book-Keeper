# AutoServis — production environment template.
# Copy to .env and fill in. Used by docker-compose.yaml (and Coolify's env UI).
# NEVER commit the filled-in .env.

# === Postgres (bundled db service) ===
POSTGRES_USER=autoservis
# Strong password for the database user (required). It is embedded into a
# postgres:// URL, so use URL-safe characters only (avoid @ : / ? # & %).
# Easiest: generate one with `openssl rand -hex 32`.
POSTGRES_PASSWORD=
POSTGRES_DB=autoservis

# === App ===
# The container always listens on the internal PORT 8080 (set in docker-compose
# for the app service). Under Coolify you do NOT publish a host port — its proxy
# reaches the container over the internal network and routes by domain, so APP_PORT
# is unused there. It only matters for a plain `docker compose up` without Coolify,
# where you'd add a `ports: ["${APP_PORT}:8080"]` mapping back to the app service.
APP_PORT=8080
# Login password for the single-user app (required).
APP_PASSWORD=
# Random signing key for sessions (required). Generate: openssl rand -hex 32
SESSION_SECRET=
# Public HTTPS origin, used to build password-reset links. e.g. https://autoservis.example.com
APP_URL=
# Comma-separated CORS allowlist. Single-origin deploy needs none — leave empty.
ALLOWED_ORIGINS=
# Log verbosity: trace|debug|info|warn|error (default info).
LOG_LEVEL=info

# === Photo storage (S3-compatible, e.g. Hetzner Object Storage) ===
STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
S3_PRIVATE_PREFIX=private
S3_PUBLIC_PREFIX=public

# === Automatic database backups ===
# When enabled in Nastavení, a gzipped JSON snapshot is uploaded daily to the
# object store under "backups/". Number of most-recent backups to keep (older
# ones are pruned automatically). Default 14.
BACKUP_RETENTION_COUNT=14

# === AI (OpenAI or any OpenAI-compatible endpoint) ===
# The vehicle-document scan (Načtení vozu) and the material/invoice extraction
# both use this single endpoint via the Responses API with an in-code prompt.
# There is no platform-managed/stored prompt — these two variables plus the
# model below are the entire AI configuration.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=
# Chat model used for document/invoice extraction (default gpt-5.5 if unset).
OPENAI_MODEL=gpt-5.5

# === Diagnostics (optional) ===
# The diagnostics page (/api/diagnostics) and its error feed are admin-only by
# default. Set this to true ONLY for a short debugging window to expose them
# without a login (e.g. a deploy whose login isn't working yet). Leave unset/off
# in normal operation.
ENABLE_PUBLIC_DIAGNOSTICS=false

# === E-mail (optional; reminders & password reset stay inert if unset) ===
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587
SMTP_SECURE=false
MAIL_FROM=
