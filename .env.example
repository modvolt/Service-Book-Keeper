# AutoServis — production environment template.
# Copy to .env and fill in. Used by docker-compose.yaml (and Coolify's env UI).
# NEVER commit the filled-in .env.

# === Postgres (bundled db service) ===
POSTGRES_USER=autoservis
# Strong password for the database user (required). It is embedded into a
# postgres:// URL, so use URL-safe characters only (avoid @ : / ? # & %).
# Easiest: generate one with `openssl rand -hex 32`.
POSTGRES_PASSWORD=
POSTGRES_DB=autoservis

# === App ===
# Host port the app is published on (Coolify usually proxies to the container).
APP_PORT=8080
# Login password for the single-user app (required).
APP_PASSWORD=
# Random signing key for sessions (required). Generate: openssl rand -hex 32
SESSION_SECRET=
# Public HTTPS origin, used to build password-reset links. e.g. https://autoservis.example.com
APP_URL=
# Comma-separated CORS allowlist. Single-origin deploy needs none — leave empty.
ALLOWED_ORIGINS=
# Log verbosity: trace|debug|info|warn|error (default info).
LOG_LEVEL=info

# === Photo storage (S3-compatible, e.g. Hetzner Object Storage) ===
STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
S3_PRIVATE_PREFIX=private
S3_PUBLIC_PREFIX=public

# === AI (OpenAI or any OpenAI-compatible endpoint) ===
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=
# Chat model used for document/invoice extraction.
OPENAI_MODEL=gpt-5.4

# === E-mail (optional; reminders & password reset stay inert if unset) ===
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587
SMTP_SECURE=false
MAIL_FROM=
